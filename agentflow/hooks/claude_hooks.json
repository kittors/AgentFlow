{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'AgentFlow EHRB check passed'",
            "description": "agentflow-safety-check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "agentflow kb sync --quiet 2>/dev/null || true",
            "description": "agentflow-kb-sync",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentflow session save --quiet --stage=SESSION_END 2>/dev/null || true",
            "description": "agentflow-session-save",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentflow --check-update --silent 2>/dev/null || true",
            "description": "agentflow-update-check"
          }
        ]
      }
    ]
  }
}
