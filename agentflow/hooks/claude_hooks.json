{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'AgentFlow EHRB check passed'",
            "description": "agentflow-safety-check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'AgentFlow progress recorded'",
            "description": "agentflow-progress-snapshot"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "agentflow --check-update --silent",
            "description": "agentflow-update-check"
          }
        ]
      }
    ]
  }
}
